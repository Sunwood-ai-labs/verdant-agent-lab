{
  "name": "verdant-agent-lab",
  "version": "0.1.0",
  "private": false,
  "description": "An original modular HTML pixel office and asset builder",
  "type": "module",
  "scripts": {
    "serve": "python3 -m http.server 4173 --directory .",
    "score:layout": "node scripts/score-layout.mjs",
    "score:similarity": "python3 scripts/score-office-similarity.py",
    "audit:sprite-bounds": "python3 scripts/audit-sprite-bounds.py",
    "trim:runtime-sprites": "python3 scripts/trim-runtime-sprites.py",
    "validate:reference-fidelity": "node scripts/validate-reference-fidelity.mjs",
    "audit:asset-provenance": "node scripts/audit-asset-provenance.mjs",
    "build:pixel-agents-pack": "python3 scripts/build-pixel-agents-pack.py",
    "build:pixel-agents-overrides": "python3 scripts/build-pixel-agents-default-overrides.py",
    "build:pixel-agents-catalog": "python3 scripts/build-pixel-agents-catalog.py",
    "build:pixel-agents-theme": "python3 scripts/build-pixel-agents-theme.py",
    "build:pixel-agents-theme-v2": "python3 scripts/build-pixel-agents-theme-v2.py",
    "validate:pixel-agents-theme-v2": "python3 scripts/validate-pixel-agents-theme-v2.py",
    "build:pixel-agents-room": "python3 scripts/build-pixel-agents-verdant-room.py",
    "build:pixel-agents-default-reskin": "python3 scripts/build-pixel-agents-default-reskin.py",
    "build:pixel-agents-solarpunk-default": "python3 scripts/build-pixel-agents-solarpunk-default-preset.py",
    "assemble:pixel-agents-solarpunk-runtime": "python3 scripts/assemble-pixel-agents-solarpunk-runtime.py",
    "validate:pixel-agents-solarpunk-default": "python3 scripts/validate-pixel-agents-solarpunk-default.py",
    "build:pixel-agents-verdant-room": "python3 scripts/build-pixel-agents-verdant-room.py",
    "verify:pixel-agents-runtime-interactions": "/Users/admin/Prj/pixel-agents/node_modules/.bin/tsx scripts/verify-pixel-agents-runtime-interactions.ts",
    "validate:pixel-agents-verdant-layout": "/Users/admin/Prj/pixel-agents/node_modules/.bin/tsx scripts/validate-pixel-agents-verdant-layout.ts",
    "build:pixel-agents-source-zones": "python3 scripts/build-pixel-agents-source-zones.py",
    "build:pixel-agents-missing-core": "python3 scripts/build-pixel-agents-missing-core.py",
    "validate:pixel-agents-pack": "python3 scripts/validate-pixel-agents-pack.py",
    "validate:sprites": "python3 scripts/validate_sprite_purity.py",
    "test": "playwright test",
    "test:update-proofs": "UPDATE_PROOFS=1 playwright test tests/proof.spec.js tests/similarity.spec.js",
    "test:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
