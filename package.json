{
  "name": "verdant-agent-lab",
  "version": "0.1.0",
  "private": false,
  "description": "An original modular HTML pixel office and asset builder",
  "type": "module",
  "scripts": {
    "serve": "python3 -m http.server 4173 --directory .",
    "score:layout": "node scripts/score-layout.mjs",
    "validate:reference-fidelity": "node scripts/validate-reference-fidelity.mjs",
    "validate:sprites": "python3 scripts/validate_sprite_purity.py",
    "test": "playwright test",
    "test:update-proofs": "UPDATE_PROOFS=1 playwright test tests/proof.spec.js",
    "test:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
